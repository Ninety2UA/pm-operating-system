# PM Operating System - .gitignore
# Excludes personal data, local config, and build artifacts.
# Template/example files are always tracked.

# ── Personal data ──────────────────────────────────────
Tasks/*.md
!Tasks/README.md
!Tasks/.gitkeep

BACKLOG.md
GOALS.md

Knowledge/People/
Knowledge/Reference/
Knowledge/journals/
Knowledge/Transcripts/
Knowledge/session-reviews/
Knowledge/decisions/
Knowledge/research/**
Knowledge/sprint-*.md
Knowledge/outcome-roadmap.md
!Knowledge/README.md
!Knowledge/.gitkeep

# Project artifacts (generated per-user)
Projects/*/prd.md
Projects/*/lean-canvas.md
Projects/*/gtm-plan.md
Projects/*/pre-mortem.md
Projects/*/user-stories.md
Projects/*/competitive-analysis.md

# ── Claude Code local config ──────────────────────────
.claude/settings.local.json
.claude/plans/
.claude/commands/

# ── MCP config (contains paths + credentials) ─────────
.mcp.json

# ── Personal/scratch files ────────────────────────────
docs/brainstorms/
docs/plans/
sync_docs.py

# ── Python ────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
.venv/
env/
.env

# ── IDE & editors ─────────────────────────────────────
.vscode/
.idea/
.obsidian/
*.swp
*.swo
*~
.DS_Store

# ── Tool-specific ─────────────────────────────────────
.specstory/
.factory/
.mcp_cache/

# ── Logs & test ───────────────────────────────────────
*.log
logs/
test_*.py
*.test.py
.pytest_cache/
.coverage
*.pid
