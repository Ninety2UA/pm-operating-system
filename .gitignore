# PM Operating System - .gitignore
# Excludes personal data, local config, and build artifacts.
# Template/example files are always tracked.

# ── Personal data ──────────────────────────────────────
tasks/*.md
!tasks/README.md
!tasks/.gitkeep

BACKLOG.md
GOALS.md

knowledge/people/*
!knowledge/people/_template.md
knowledge/reference/*
!knowledge/reference/okr-history.md
knowledge/journals/
knowledge/meetings/
knowledge/session-reviews/
knowledge/decisions/
knowledge/research/**
knowledge/sprint-*.md
knowledge/outcome-roadmap.md
knowledge/updates/
knowledge/decks/
knowledge/voice-samples/
knowledge/voice-guide.md
!knowledge/README.md
!knowledge/.gitkeep

# Projects are personal; only the template README is tracked.
projects/*
!projects/README.md

# ── Claude Code local config ──────────────────────────
.claude/settings.local.json
.claude/plans/
.claude/*.lock
.claude/hooks/*.log

# ── Personal/scratch files ────────────────────────────
docs/brainstorms/
docs/plans/

# Browser downloads and throwaway artifacts at repo root
/*.html
/*.pdf

# ── Node (make-slides / playwright deps) ──────────────
node_modules/
package-lock.json

# ── Python ────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
.venv/
env/
.env

# ── IDE & editors ─────────────────────────────────────
.vscode/
.idea/
.obsidian/
*.swp
*.swo
*~
.DS_Store

# ── Tool-specific ─────────────────────────────────────
.specstory/
.factory/
.mcp_cache/

# ── Generated sites ───────────────────────────────────
site/
gh-pages/

# ── Logs & test ───────────────────────────────────────
*.log
logs/
test_*.py
*.test.py
.pytest_cache/
.coverage
*.pid
