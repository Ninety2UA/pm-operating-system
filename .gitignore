# PM Operating System - .gitignore
# Excludes personal data, local config, and build artifacts.
# Template/example files are always tracked.

# ── Personal data ──────────────────────────────────────
tasks/*.md
!tasks/README.md
!tasks/.gitkeep

BACKLOG.md
GOALS.md

knowledge/people/
knowledge/reference/
!knowledge/reference/PM_OS_GUIDE.md
knowledge/journals/
knowledge/meetings/
knowledge/session-reviews/
knowledge/decisions/
knowledge/research/**
knowledge/sprint-*.md
knowledge/outcome-roadmap.md
!knowledge/README.md
!knowledge/.gitkeep

# Project artifacts (generated per-user)
projects/*/prd.md
projects/*/lean-canvas.md
projects/*/gtm-plan.md
projects/*/pre-mortem.md
projects/*/user-stories.md
projects/*/competitive-analysis.md

# ── Claude Code local config ──────────────────────────
.claude/settings.local.json
.claude/plans/
.claude/commands/

# ── MCP config (contains paths + credentials) ─────────
.mcp.json

# ── Personal/scratch files ────────────────────────────
docs/brainstorms/
docs/plans/
sync_docs.py

# ── Python ────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
.venv/
env/
.env

# ── IDE & editors ─────────────────────────────────────
.vscode/
.idea/
.obsidian/
*.swp
*.swo
*~
.DS_Store

# ── Tool-specific ─────────────────────────────────────
.specstory/
.factory/
.mcp_cache/

# ── Generated sites ───────────────────────────────────
site/
gh-pages/

# ── Logs & test ───────────────────────────────────────
*.log
logs/
test_*.py
*.test.py
.pytest_cache/
.coverage
*.pid
