# PM Operating System - .gitignore
# Excludes personal data, local config, and build artifacts.
# Template/example files are always tracked.

# ── Personal data ──────────────────────────────────────
tasks/*.md
!tasks/README.md
!tasks/.gitkeep

BACKLOG.md
GOALS.md

knowledge/people/*
!knowledge/people/_template.md
knowledge/reference/*
!knowledge/reference/okr-history.md
knowledge/journals/
knowledge/meetings/
knowledge/session-reviews/
knowledge/decisions/
knowledge/research/**
knowledge/sprint-*.md
knowledge/outcome-roadmap.md
!knowledge/README.md
!knowledge/.gitkeep

# Project artifacts (generated per-user)
projects/*/prd.md
projects/*/lean-canvas.md
projects/*/gtm-plan.md
projects/*/pre-mortem.md
projects/*/user-stories.md
projects/*/competitive-analysis.md

# ── Claude Code local config ──────────────────────────
.claude/settings.local.json
.claude/plans/

# ── Personal/scratch files ────────────────────────────
docs/brainstorms/
docs/plans/

# ── Python ────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
.Python
venv/
.venv/
env/
.env

# ── IDE & editors ─────────────────────────────────────
.vscode/
.idea/
.obsidian/
*.swp
*.swo
*~
.DS_Store

# ── Tool-specific ─────────────────────────────────────
.specstory/
.factory/
.mcp_cache/

# ── Generated sites ───────────────────────────────────
site/
gh-pages/

# ── Logs & test ───────────────────────────────────────
*.log
logs/
test_*.py
*.test.py
.pytest_cache/
.coverage
*.pid
