{
  "mcpServers": {
    "manager-ai": {
      "command": "uv",
      "args": [
        "--directory",
        "./core/mcp",
        "run",
        "server.py"
      ],
      "env": {
        "MANAGER_AI_BASE_DIR": "."
      }
    },
    "perplexity": {
      "command": "npx",
      "args": ["-y", "@perplexity-ai/mcp-server"],
      "env": {
        "PERPLEXITY_API_KEY": "${PERPLEXITY_API_KEY}"
      }
    },
    "granola": {
      "type": "http",
      "url": "https://mcp.granola.ai/mcp"
    }
  }
}
