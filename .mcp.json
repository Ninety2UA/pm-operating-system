{
  "mcpServers": {
    "manager-ai": {
      "command": "uv",
      "args": [
        "--directory",
        "./core/mcp",
        "run",
        "server.py"
      ],
      "env": {
        "MANAGER_AI_BASE_DIR": "."
      }
    },
    "granola": {
      "type": "http",
      "url": "https://mcp.granola.ai/mcp"
    }
  }
}
